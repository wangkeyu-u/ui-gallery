{
  "name": "ui-gallery",
  "version": "3.0.0",
  "description": "AI-driven UI discovery, aesthetic judgment, and theme creation tool",
  "type": "module",
  "license": "MIT",
  "author": "wangkeyu-u",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangkeyu-u/ui-gallery.git"
  },
  "homepage": "https://wangkeyu-u.github.io/ui-gallery/",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && rm -rf dist && vite build",
    "preview": "vite preview",
    "migrate": "node scripts/migrate-data.cjs",
    "audit": "node scripts/audit-previews.cjs",
    "verify:data": "node scripts/verify-data.cjs",
    "test:smoke": "node scripts/smoke-app.cjs",
    "test": "npm run verify:data && npm run test:smoke",
    "check": "npm run audit && npm run verify:data && npm run build && npm run test:smoke",
    "check:full": "npm run check && npm run repro:validate-all && npm audit --audit-level=high",
    "repro:migrate": "node scripts/migrate-repro.cjs",
    "repro:pack": "node scripts/repro-pack.cjs",
    "repro:validate": "node scripts/repro-validate.cjs",
    "repro:validate-all": "node scripts/repro-validate.cjs --all",
    "repro:summary": "node scripts/repro-summary.cjs",
    "serve": "python3 -m http.server 4173 --directory dist",
    "deploy": "gh workflow run pages.yml --ref main"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.61.1",
    "sharp": "^0.33.5",
    "typescript": "^5.5.3",
    "vite": "^8.1.4"
  }
}
